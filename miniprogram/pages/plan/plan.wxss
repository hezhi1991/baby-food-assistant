.header {
  margin-bottom: 30rpx;
}

.title {
  font-size: 48rpx;
}

.add-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  padding: 0;
}

.calendar-strip {
  padding: 20rpx 0;
}

.date-scroll {
  white-space: nowrap;
  width: 100%;
}

.date-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  width: 100rpx;
  padding: 20rpx 0;
  margin: 0 10rpx;
  border-radius: 20rpx;
  transition: all 0.2s;
}

.date-item.active {
  background: #fff4e5;
  border: 2rpx solid #ff9600;
}

.day-name {
  font-size: 20rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.day-num {
  font-size: 32rpx;
}

.section-title {
  font-size: 32rpx;
  margin: 40rpx 0 20rpx;
}

.plan-card {
  margin-bottom: 30rpx;
}

.plan-type-tag {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 10rpx;
}

.plan-type-tag.milk {
  background: #e3f2fd;
  color: #2196f3;
}

.plan-type-tag.food {
  background: #f1f8e9;
  color: #4caf50;
}

.plan-time {
  font-size: 32rpx;
}

.plan-body {
  padding: 20rpx 0;
}

.plan-desc {
  font-size: 28rpx;
  color: #333;
}

.plan-footer {
  border-top: 2rpx solid #f0f0f0;
  padding-top: 20rpx;
  margin-top: 10rpx;
}

.action-links {
  display: flex;
  gap: 30rpx;
}

.edit-link {
  font-size: 24rpx;
  color: #2196f3;
}

.delete-link {
  font-size: 24rpx;
  color: #f44336;
}

.complete-btn {
  background: #ff9600;
  color: #fff;
  font-size: 24rpx;
  padding: 10rpx 30rpx;
  border-radius: 40rpx;
  font-weight: 900;
}

.complete-btn.done {
  background: #f0f0f0;
  color: #999;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

.empty-img {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

/* Modal */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.modal-content {
  width: 80%;
  padding: 40rpx;
}

.modal-header {
  margin-bottom: 40rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.label {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 10rpx;
}

.picker-val {
  background: #f7f7f7;
  padding: 20rpx;
  border-radius: 10rpx;
  font-size: 28rpx;
}

.radio-label {
  margin-right: 30rpx;
  font-size: 28rpx;
}

.form-input {
  background: #f7f7f7;
  width: 100%;
  padding: 20rpx;
  border-radius: 10rpx;
  font-size: 28rpx;
  height: 150rpx;
  box-sizing: border-box;
}
