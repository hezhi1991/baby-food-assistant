.header {
  margin-bottom: 30rpx;
}

.title {
  font-size: 48rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  padding: 10rpx 30rpx;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.search-bar input {
  flex: 1;
  font-size: 28rpx;
}

.category-scroll {
  white-space: nowrap;
  margin-bottom: 40rpx;
}

.cat-item {
  display: inline-block;
  padding: 10rpx 30rpx;
  margin-right: 20rpx;
  font-size: 28rpx;
  color: #666;
  border-radius: 30rpx;
  background: #fff;
  border: 2rpx solid #eee;
}

.cat-item.active {
  background: #ff9600;
  color: #fff;
  border-color: #e68700;
}

.recipe-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.recipe-card {
  padding: 0;
  overflow: hidden;
}

.recipe-img {
  width: 100%;
  height: 240rpx;
  background: #f0f0f0;
}

.recipe-info {
  padding: 20rpx;
}

.recipe-name {
  font-size: 28rpx;
  display: block;
  margin-bottom: 10rpx;
}

.recipe-meta {
  display: flex;
  justify-content: space-between;
  font-size: 20rpx;
  color: #999;
}

.age-tag {
  background: #fff4e5;
  color: #ff9600;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
}
