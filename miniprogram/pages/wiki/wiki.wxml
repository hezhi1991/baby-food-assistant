<view class="container">
  <view class="header">
    <text class="title text-bold">育儿百科</text>
  </view>

  <view class="wiki-list">
    <view wx:for="{{articles}}" wx:key="id" class="wiki-card duo-card" bindtap="viewArticle" data-id="{{item.id}}">
      <view class="wiki-info">
        <text class="wiki-title text-bold">{{item.title}}</text>
        <text class="wiki-summary">{{item.summary}}</text>
      </view>
      <text class="arrow">></text>
    </view>
  </view>
</view>
