rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId
    // Fields:
    //   - babyName: string (required)
    //   - babyAge: string
    //   - babyStage: string
    //   - babyPhoto: string
    //   - allergicIngredients: list
    //   - safeIngredients: list
    //   - role: string
    //
    // Collection: meals
    // Document ID: mealId
    // Fields:
    //   - uid: string (required)
    //   - date: string (required)
    //   - time: string (required)
    //   - type: string (required)
    //   - foods: list
    //   - milkType: string
    //   - milkVolume: number
    //   - actualMilkVolume: number
    //   - isCompleted: bool
    //   - photos: list
    //   - comments: list
    //   - generatedBy: string
    //   - completedBy: string
    //
    // Collection: vitamins
    // Document ID: vitaminId
    // Fields:
    //   - uid: string (required)
    //   - date: string (required)
    //   - type: string (required)
    //   - isCompleted: bool
    //   - completedBy: string
    //
    // Collection: weightRecords
    // Document ID: weightId
    // Fields:
    //   - uid: string (required)
    //   - date: string (required)
    //   - weight: number (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }
    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "hezhi1991@gmail.com" && request.auth.token.email_verified == true));
    }
    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }
    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser(data) {
      return data.babyName is string && data.babyName.size() > 0 && data.babyName.size() < 100 &&
             (!('babyAge' in data) || data.babyAge is string) &&
             (!('babyStage' in data) || data.babyStage is string) &&
             (!('babyPhoto' in data) || data.babyPhoto is string) &&
             (!('allergicIngredients' in data) || data.allergicIngredients is list) &&
             (!('safeIngredients' in data) || data.safeIngredients is list) &&
             (!('role' in data) || data.role is string);
    }

    function isValidMeal(data) {
      return data.uid is string && data.uid == request.auth.uid &&
             data.date is string && data.time is string &&
             data.type in ['milk', 'food'] &&
             (!('foods' in data) || data.foods is list) &&
             (!('milkVolume' in data) || data.milkVolume is number) &&
             (!('actualMilkVolume' in data) || data.actualMilkVolume is number) &&
             (!('isCompleted' in data) || data.isCompleted is bool) &&
             (!('photos' in data) || data.photos is list) &&
             (!('comments' in data) || data.comments is list);
    }

    function isValidVitamin(data) {
      return data.uid is string && data.uid == request.auth.uid &&
             data.date is string && data.type in ['D', 'AD'] &&
             (!('isCompleted' in data) || data.isCompleted is bool);
    }

    function isValidWeight(data) {
      return data.uid is string && data.uid == request.auth.uid &&
             data.date is string && data.weight is number;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /meals/{mealId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidMeal(request.resource.data) && uidUnchanged();
      allow update: if (isDocOwner() || isAdmin()) && isValidMeal(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner() || isAdmin();
    }

    match /vitamins/{vitaminId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidVitamin(request.resource.data) && uidUnchanged();
      allow update: if (isDocOwner() || isAdmin()) && isValidVitamin(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner() || isAdmin();
    }

    match /weightRecords/{weightId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidWeight(request.resource.data) && uidUnchanged();
      allow update: if (isDocOwner() || isAdmin()) && isValidWeight(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner() || isAdmin();
    }
  }
}
