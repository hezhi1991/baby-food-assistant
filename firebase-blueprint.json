{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User's baby profile and settings",
      "type": "object",
      "properties": {
        "babyName": { "type": "string" },
        "babyBirthday": { "type": "string" },
        "babyPhoto": { "type": "string" },
        "role": { "type": "string" }
      }
    },
    "FamilyMember": {
      "title": "Family Member",
      "description": "A family member associated with the account",
      "type": "object",
      "properties": {
        "username": { "type": "string" },
        "role": { "type": "string" },
        "isPrimary": { "type": "boolean" }
      }
    },
    "Meal": {
      "title": "Meal Record",
      "description": "A feeding or meal record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "type": { "type": "string" },
        "foods": { "type": "array", "items": { "type": "object" } },
        "milkType": { "type": "string" },
        "milkVolume": { "type": "number" },
        "actualMilkVolume": { "type": "number" },
        "isCompleted": { "type": "boolean" },
        "photos": { "type": "array", "items": { "type": "string" } },
        "comments": { "type": "array", "items": { "type": "object" } },
        "generatedBy": { "type": "string" },
        "completedBy": { "type": "string" }
      }
    },
    "Vitamin": {
      "title": "Vitamin Record",
      "description": "A vitamin intake record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "type": { "type": "string" },
        "isCompleted": { "type": "boolean" },
        "completedBy": { "type": "string" }
      }
    },
    "Weight": {
      "title": "Weight Record",
      "description": "A baby weight record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "weight": { "type": "number" }
      }
    },
    "Poop": {
      "title": "Poop Record",
      "description": "A baby poop record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "role": { "type": "string" }
      }
    },
    "Sleep": {
      "title": "Sleep Record",
      "description": "A baby sleep record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "startTime": { "type": "string" },
        "endTime": { "type": "string" },
        "durationMinutes": { "type": "number" },
        "role": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Main user document"
    },
    "/users/{userId}/members/{memberId}": {
      "schema": "FamilyMember",
      "description": "Family members sub-collection"
    },
    "/users/{userId}/meals/{mealId}": {
      "schema": "Meal",
      "description": "Meals sub-collection"
    },
    "/users/{userId}/vitamins/{vitaminId}": {
      "schema": "Vitamin",
      "description": "Vitamins sub-collection"
    },
    "/users/{userId}/weightRecords/{weightId}": {
      "schema": "Weight",
      "description": "Weight records sub-collection"
    },
    "/users/{userId}/poopRecords/{poopId}": {
      "schema": "Poop",
      "description": "Poop records sub-collection"
    },
    "/users/{userId}/sleepRecords/{sleepId}": {
      "schema": "Sleep",
      "description": "Sleep records sub-collection"
    }
  }
}
